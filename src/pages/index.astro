---
import ContainerSection from "../components/ContainerSection.astro";
import Disponible from "../components/Disponible.astro";
import Experiencia from "../components/Experiencia.astro";
import FormMessage from "../components/FormMessage";
import Iconos from "../components/Iconos.astro";
import Projects from "../components/Projects.astro";
import SectionTitles from "../components/SectionTitles.astro";
import Brief from "../icons/Brief.astro";
import Code from "../icons/Code.astro";
import Contact from "../icons/Contact.astro";
import Github from "../icons/Github.astro";
import Linkedin from "../icons/Linkedin.astro";
import Mail from "../icons/Mail.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="w-full pt-24">

    <!-- Hero -->
    <ContainerSection id="top">
      <div class="flex flex-col items-center text-center gap-6 max-w-2xl mx-auto">

        <!-- Foto de perfil -->
        <div class="relative group">
          <div class="absolute inset-0 rounded-2xl bg-[#2f6fe3]/20 blur-2xl scale-90 group-hover:scale-100 group-hover:bg-[#2f6fe3]/30 transition-all duration-500"></div>
          <img
            src="/perfil.jpg"
            alt="Foto de perfil de Jhonjandrys"
            class="relative w-36 h-36 sm:w-44 sm:h-44 rounded-2xl object-cover border border-white/10 shadow-2xl"
          />
        </div>

        <!-- Badge -->
        <a href="https://www.linkedin.com/in/jhonjandrysdev/" target="_blank" rel="noopener">
          <Disponible>En EFICI SAS 🚀</Disponible>
        </a>

        <!-- Nombre -->
        <div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight leading-tight">
            Hola, soy <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#2f6fe3] to-[#6fa3ff]">Jhonjandrys</span>
          </h1>
        </div>

        <!-- Descripción -->
        <p class="text-base sm:text-lg text-white/55 max-w-xl leading-relaxed">
          <span class="text-white font-semibold">Desarrollador Fullstack</span> con +2 años de experiencia.
          Actualmente en <span class="text-[#2f6fe3] font-semibold">EFICI SAS</span>, construyendo soluciones web modernas con IA.
        </p>

        <!-- Links sociales -->
        <nav class="flex flex-wrap justify-center gap-2">
          <Iconos href="https://www.linkedin.com/in/jhonjandrysdev/">
            <Linkedin class="size-4" />
            LinkedIn
          </Iconos>
          <Iconos href="https://github.com/Jhonjandrysdev">
            <Github class="size-4" />
            GitHub
          </Iconos>
          <Iconos href="mailto:jhonjandrysramirez10@gmail.com">
            <Mail class="size-4" />
            jhonjandrysramirez10@gmail.com
          </Iconos>
        </nav>

      </div>
    </ContainerSection>

    <!-- Experiencia -->
    <ContainerSection id="experiencia">
      <SectionTitles titulo="Experiencia Laboral">
        <Brief class="size-4" />
      </SectionTitles>
      <Experiencia />
    </ContainerSection>

    <!-- Proyectos -->
    <ContainerSection id="proyectos">
      <SectionTitles titulo="Proyectos">
        <Code class="size-4" />
      </SectionTitles>
      <Projects />
    </ContainerSection>

    <!-- Contacto -->
    <ContainerSection id="contacto">
      <SectionTitles titulo="Contáctame">
        <Contact class="size-4" />
      </SectionTitles>
      <FormMessage client:only="react" />
    </ContainerSection>

  </main>
</Layout>
