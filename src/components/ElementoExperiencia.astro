---
const { Fecha, Titulo, Empresa, EmpresaLink, Descripcion } = Astro.props;
---

<div class="group relative flex gap-4 rounded-2xl border border-white/8 bg-white/[0.03] p-6 hover:border-[#2f6fe3]/30 hover:bg-white/[0.05] transition-all duration-300">
  <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[#2f6fe3]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>

  <div class="shrink-0 mt-0.5">
    <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-[#2f6fe3]/15 border border-[#2f6fe3]/30 group-hover:bg-[#2f6fe3]/25 transition-colors">
      <svg class="w-4 h-4 text-[#2f6fe3]" fill="currentColor" viewBox="0 0 20 20">
        <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z" />
      </svg>
    </div>
  </div>

  <div class="flex flex-col gap-2 flex-1 relative">
    <time class="text-xs font-semibold text-[#2f6fe3] tracking-widest uppercase">
      {Fecha}
    </time>
    <h3 class="text-base font-bold text-white leading-snug">
      {Titulo}
      {Empresa && EmpresaLink && (
        <span class="font-normal text-white/50"> — </span>
        <a
          href={EmpresaLink}
          target="_blank"
          rel="noopener noreferrer"
          class="font-bold text-[#2f6fe3] hover:underline hover:text-[#6fa3ff] transition-colors"
        >
          {Empresa}
        </a>
      )}
      {Empresa && !EmpresaLink && (
        <span class="font-normal text-white/50"> — </span>
        <span class="font-bold text-white/80">{Empresa}</span>
      )}
    </h3>
    <p class="text-sm leading-relaxed text-white/50">
      {Descripcion}
    </p>
  </div>
</div>
