---
import Github from "../icons/Github.astro";
import Linkedin from "../icons/Linkedin.astro";
---

<footer class="w-full max-w-3xl mx-auto px-4 pb-10 mt-4">
  <div class="rounded-2xl border border-white/8 bg-white/[0.03] px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-white/40">
      © 2025 <span class="text-white/70 font-medium">Jhonjandrys Ramirez</span>. Todos los derechos reservados.
    </p>
    <div class="flex items-center gap-3">
      <a
        href="https://www.linkedin.com/in/jhonjandrysdev/"
        target="_blank"
        rel="noopener noreferrer"
        class="p-2 rounded-xl bg-white/5 border border-white/8 hover:border-[#2f6fe3]/40 hover:bg-[#2f6fe3]/10 text-white/50 hover:text-[#2f6fe3] transition-all duration-200"
        aria-label="LinkedIn"
      >
        <Linkedin class="size-4" />
      </a>
      <a
        href="https://github.com/Jhonjandrysdev"
        target="_blank"
        rel="noopener noreferrer"
        class="p-2 rounded-xl bg-white/5 border border-white/8 hover:border-[#2f6fe3]/40 hover:bg-[#2f6fe3]/10 text-white/50 hover:text-[#2f6fe3] transition-all duration-200"
        aria-label="GitHub"
      >
        <Github class="size-4" />
      </a>
    </div>
  </div>
</footer>
