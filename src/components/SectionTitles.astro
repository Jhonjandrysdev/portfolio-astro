---
const { titulo } = Astro.props;
---

<div class="flex items-center gap-3 mb-5 md:mb-7">
  <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-[#2f6fe3]/15 border border-[#2f6fe3]/30 text-[#2f6fe3] shrink-0">
    <slot />
  </div>
  <h2 class="text-2xl font-bold text-white">{titulo}</h2>
  <div class="flex-1 h-px bg-gradient-to-r from-white/10 to-transparent"></div>
</div>
