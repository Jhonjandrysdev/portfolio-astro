---
const { href } = Astro.props;
---
<a
  class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl text-sm font-medium text-white/70 hover:text-white bg-white/5 hover:bg-white/10 border border-white/8 hover:border-white/15 transition-all duration-200 hover:scale-[1.03]"
  href={href}
  target={href ? "_blank" : undefined}
  rel={href ? "noopener noreferrer" : undefined}
>
  <slot />
</a>
