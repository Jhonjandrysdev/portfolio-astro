---
import ElementoExperiencia from "./ElementoExperiencia.astro"

const experiencia = [
  {
    Fecha: "Noviembre 2025 - Actualidad",
    Titulo: "Desarrollador Fullstack",
    Empresa: "EFICI SAS",
    EmpresaLink: "https://efici.co/",
    Descripcion: "Desarrollo de módulos fullstack para EFICI, plataforma SaaS para gestión de pequeños y medianos comercios. Lidero el desarrollo del módulo Social IA: automatización de publicaciones en redes sociales con IA, calendario editorial, métricas de rendimiento por perfil y generación de contenido segmentado por audiencia.",
    Link: "#proyectos"
  },
  {
    Fecha: "Octubre 2023 - Noviembre 2025",
    Titulo: "Desarrollador Frontend Freelance",
    Empresa: null,
    EmpresaLink: null,
    Descripcion: "Desarrollo de aplicaciones web modernas e interactivas como freelance durante más de 2 años. Participé en proyectos destacados como landing pages, clones de plataformas y herramientas de productividad, utilizando React, JavaScript, Tailwind CSS y Firebase. Enfoque en experiencias de usuario intuitivas y código escalable.",
    Link: "#proyectos"
  }
];
---

<ol class="flex flex-col gap-4">
    {
        experiencia.map((exp) => (
            <li class="relative">
                <ElementoExperiencia {...exp}/>
            </li>
        ))
    }
</ol>

