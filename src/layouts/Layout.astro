---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "@fontsource-variable/onest";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Portafolio de Jhonjandrys Ramirez, desarrollador Fullstack con más de 2 años de experiencia. Actualmente en EFICI SAS." />
    <meta name="keywords" content="Desarrollador Web, Programador Web, Jhonjandrys Ramirez, Portafolio Web, Fullstack, React, Astro" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/icon1.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Jhonjandrys Ramirez | Desarrollador Fullstack</title>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --color-blue: #2f6fe3;
    --color-blue-dark: #1a4db5;
    --color-bg: #06060f;
    --color-card: rgba(255, 255, 255, 0.04);
    --color-border: rgba(255, 255, 255, 0.08);
    --color-text-muted: #94a3b8;
  }

  html {
    width: 100%;
    scroll-behavior: smooth;
    background-color: var(--color-bg);
  }

  body {
    width: 100%;
    margin: 0;
    font-family: "Onest Variable", sans-serif;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(47, 111, 227, 0.15) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 80% 100%, rgba(47, 111, 227, 0.08) 0%, transparent 60%),
      var(--color-bg);
    min-height: 100vh;
    color: white;
    overflow-x: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
  }

  ::selection {
    background: rgba(47, 111, 227, 0.4);
    color: white;
  }

  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--color-blue-dark);
    border-radius: 3px;
  }
</style>
